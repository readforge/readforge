{
  "name": "readforge",
  "version": "1.7.12",
  "private": true,
  "description": "ReadForge - a modern Windows EPUB reader with read-aloud, themes, library covers, and reading progress.",
  "main": "electron/main.cjs",
  "author": "ReadForge",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron .",
    "build": "vite build",
    "dist": "vite build && electron-builder --win nsis"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "jszip": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest",
    "electron-updater": "^6.6.2",
    "electron-log": "^5.4.3"
  },
  "devDependencies": {
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.readforge.reader",
    "productName": "ReadForge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ReadForge"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "readforge",
        "repo": "readforge"
      }
    ],
    "artifactName": "ReadForge-Setup-${version}.${ext}"
  }
}
